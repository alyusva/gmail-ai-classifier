# ============================================
# ANTHROPIC API (Claude)
# ============================================
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# GOOGLE OAUTH (Gmail API)
# ============================================
# Instrucciones en README.md para obtener credentials.json
# No se usa variable de entorno, se carga desde credentials.json

# ============================================
# SUPABASE (Base de datos en la nube)
# ============================================
# Obtén estos valores en: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# ============================================
# CONFIGURACIÓN DEL CLASIFICADOR
# ============================================
# Tamaño de lote para clasificación (emails procesados por llamada a Claude)
CLASSIFY_BATCH_SIZE=50

# Prefijo para las etiquetas en Gmail (vacío = sin prefijo)
LABEL_PREFIX=

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# WEB APP (Solo para producción)
# ============================================
# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para JWT (generar con: openssl rand -base64 32)
JWT_SECRET=tu-secret-key-super-seguro-aqui

# Modo de ejecución
NODE_ENV=development
